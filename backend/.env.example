# Must match the device_id provisioned onto the real ESP32 (BLE provisioning
# "device_id" field). Falls back to the firmware's own default if unprovisioned.
DEVICE_ID=ESP32_AquaGuard

MQTT_HOST=broker.hivemq.com
MQTT_PORT=1883

DATABASE_URL=postgresql+psycopg://aquaguard:aquaguard@localhost:5439/aquaguard

FAKE_DATA_INTERVAL_SECONDS=30

# Comma-separated list of origins allowed to call this API from a browser.
CORS_ORIGINS=http://localhost:5173
